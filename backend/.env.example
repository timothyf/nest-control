# ── Server ───────────────────────────────────────────────
PORT=3000

# ── Nest / Google SDM ────────────────────────────────────
# Your Google Device Access project ID
NEST_PROJECT_ID=your-google-device-access-project-id

# OAuth 2.0 credentials from Google Cloud Console
NEST_CLIENT_ID=your-oauth-client-id
NEST_CLIENT_SECRET=your-oauth-client-secret

# Refresh token obtained after completing the OAuth 2.0 authorization flow
# See README for instructions on obtaining this token
NEST_REFRESH_TOKEN=your-refresh-token

# ── Weather (Open-Meteo) ─────────────────────────────────
# Coordinates for weather data (defaults to San Francisco, CA)
WEATHER_LATITUDE=37.7749
WEATHER_LONGITUDE=-122.4194
